---
import Base from "../layouts/Base.astro";
import WipBanner from "../components/WipBanner.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Sterilization from "../components/Sterilization.astro";
import Gallery from "../components/Gallery.astro";
// Testimonials is parked until Ana has real client reviews — shipping invented
// quotes labelled "Exemplu" advertised that the proof was fake, which hurt
// trust more than the section's absence. Re-enable below once the quotes in
// src/content/testimonials.ts are genuine.
// import Testimonials from "../components/Testimonials.astro";
import Loyalty from "../components/Loyalty.astro";
import Faq from "../components/Faq.astro";
import Booking from "../components/Booking.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import MobileBookingBar from "../components/MobileBookingBar.astro";
---

<Base>
  <WipBanner />
  <Nav />
  <main>
    <Hero />
    <About />
    <Services />
    <Sterilization />
    <Gallery />
    {/* <Testimonials /> — parked until real reviews exist (see import above) */}
    <Loyalty />
    <Faq />
    <Booking />
    <Contact />
  </main>
  <Footer />
  <MobileBookingBar />
</Base>
