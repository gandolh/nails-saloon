---
import { services } from "../content/services";

const icons: Record<string, string> = {
  manichiura: `<path d="M12 3c-2 0-3 1.5-3 4v9a3 3 0 0 0 6 0V7c0-2.5-1-4-3-4z"/><line x1="9" y1="10" x2="15" y2="10"/>`,
  "unghii-gel": `<path d="M12 2c-2 0-3.5 1.5-3.5 4v12a3.5 3.5 0 0 0 7 0V6c0-2.5-1.5-4-3.5-4z"/><path d="M12 2v20"/>`,
  "nail-art": `<path d="M3 21l9-9 3 3-9 9H3z"/><path d="M14 6l1.5-1.5a2.121 2.121 0 0 1 3 3L17 9"/><circle cx="18" cy="4" r="0.6" fill="currentColor"/><circle cx="20" cy="7" r="0.6" fill="currentColor"/>`,
};
---

<section id="servicii" class="section">
  <div class="container-page">
    <div class="reveal max-w-2xl">
      <span class="label-md uppercase text-[var(--color-secondary)]">
        Serviciile mele
      </span>
      <h2 class="heading-lg mt-3">Servicii & prețuri</h2>
      <span class="gold-divider"></span>
      <p class="mt-4 text-[var(--color-on-surface-variant)]">
        Prețuri orientative. Pentru o ofertă personalizată, contactează-mă pe
        WhatsApp.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        services.map((s) => (
          <article
            class="card reveal flex flex-col"
          >
            <div
              class="w-12 h-12 rounded-full bg-[var(--color-primary-container)] text-[var(--color-on-primary-container)] flex items-center justify-center"
              aria-hidden="true"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[s.id] ?? ""}
              />
            </div>

            <h3 class="heading-md mt-6">{s.title}</h3>
            <p class="label-md uppercase mt-2 text-[var(--color-secondary)]">
              {s.subtitle}
            </p>
            <p class="mt-4 text-[var(--color-on-surface-variant)] leading-relaxed flex-1">
              {s.description}
            </p>
            <div
              class="mt-6 pt-6 border-t border-[var(--color-outline-variant)] flex items-baseline justify-between"
            >
              <span
                class="font-display text-xl text-[var(--color-gold)]"
                style="font-family: 'Playfair Display', Georgia, serif;"
              >
                {s.price}
              </span>
              <a
                href="#programari"
                class="label-md uppercase text-[var(--color-on-surface)] hover:text-[var(--color-blush-deep)]"
              >
                Programează →
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <a href="#programari" class="btn btn-primary">Programează-te</a>
    </div>
  </div>
</section>
