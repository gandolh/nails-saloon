---
// Hygiene & sterilisation — a strong trust signal in the RO market. Icon-based,
// no imagery needed. Mirrors the on-brand blush/cream/gold tokens.
const points = [
  {
    title: "Sterilizare în autoclav",
    body: "Instrumentarul metalic este sterilizat în autoclav după fiecare clientă — standardul medical pentru eliminarea completă a microorganismelor.",
    icon: `<path d="M4 7h16M6 7v11a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/><line x1="12" y1="11" x2="12" y2="16"/>`,
  },
  {
    title: "Consumabile de unică folosință",
    body: "Pilele, buffer-ele și alte consumabile care nu se pot steriliza sunt de unică folosință — proaspete pentru fiecare programare.",
    icon: `<path d="M3 6h18l-1.5 14a2 2 0 0 1-2 2H6.5a2 2 0 0 1-2-2L3 6z"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>`,
  },
  {
    title: "Dezinfecție & suprafețe curate",
    body: "Masa de lucru, lampa și suprafețele sunt dezinfectate între cliente, iar mâinile — igienizate riguros înainte de fiecare serviciu.",
    icon: `<path d="M12 2s6 5 6 11a6 6 0 0 1-12 0c0-6 6-11 6-11z"/><path d="M9.5 13a2.5 2.5 0 0 0 5 0"/>`,
  },
];
---

<section id="igiena" class="section bg-[var(--color-surface-container-low)]">
  <div class="container-page">
    <div class="reveal max-w-2xl">
      <span class="label-md uppercase text-[var(--color-secondary)]">
        Igienă & siguranță
      </span>
      <h2 class="heading-lg mt-3">Curățenie fără compromisuri</h2>
      <span class="gold-divider"></span>
      <p class="mt-4 text-[var(--color-on-surface-variant)]">
        Sănătatea ta contează la fel de mult ca aspectul unghiilor. Iată cum am
        grijă de igienă la fiecare programare.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        points.map((p) => (
          <article class="card reveal flex flex-col">
            <div
              class="w-12 h-12 rounded-full bg-[var(--color-primary-container)] text-[var(--color-on-primary-container)] flex items-center justify-center"
              aria-hidden="true"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={p.icon}
              />
            </div>
            <h3 class="heading-md mt-6">{p.title}</h3>
            <p class="mt-3 text-[var(--color-on-surface-variant)] leading-relaxed">
              {p.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
