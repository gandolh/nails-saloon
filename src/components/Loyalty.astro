---
---

<section id="loialitate" class="section">
  <div class="container-page">
    <div
      class="reveal relative rounded-[1.5rem] overflow-hidden bg-[var(--color-primary-container)] px-8 md:px-16 py-12 md:py-20"
    >
      <!-- Decorative gold motif -->
      <div
        aria-hidden="true"
        class="loyalty-gold-motif absolute -top-12 -right-12 w-48 h-48 rounded-full opacity-30"
      >
      </div>

      <div class="relative grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="heading-lg text-[var(--color-on-primary-container)]">
            Cu cât vii mai des, cu atât te răsfeți mai mult.
          </h2>
          <span class="gold-divider"></span>
        </div>

        <div class="space-y-5">
          <div class="flex gap-4 items-start">
            <div
              class="flex-shrink-0 w-10 h-10 rounded-full bg-white text-[var(--color-on-primary-container)] flex items-center justify-center font-display text-lg"
            >
              5
            </div>
            <p class="text-[var(--color-on-surface)] leading-relaxed">
              La fiecare <strong>a 5-a programare</strong>, primești
              <strong>20% reducere</strong> la serviciul ales. Ne ținem evidența,
              tu te bucuri de unghii frumoase.
            </p>
          </div>

          <div class="flex gap-4 items-start">
            <div
              class="flex-shrink-0 w-10 h-10 rounded-full bg-white text-[var(--color-on-primary-container)] flex items-center justify-center"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <p class="text-[var(--color-on-surface)] leading-relaxed">
              <strong>Recomandă o prietenă</strong> și primiți amândouă
              <strong>10% reducere</strong> la următoarea vizită.
            </p>
          </div>

          <div class="flex gap-4 items-start">
            <div
              class="flex-shrink-0 w-10 h-10 rounded-full bg-white text-[var(--color-on-primary-container)] flex items-center justify-center"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="8" width="18" height="13" rx="1"/>
                <path d="M3 8h18M12 8v13"/>
                <path d="M12 8S9 2 6.5 3.5 8 8 12 8zm0 0s3-6 5.5-4.5S16 8 12 8z"/>
              </svg>
            </div>
            <p class="text-[var(--color-on-surface)] leading-relaxed">
              <strong>Voucher cadou</strong>: surprinde pe cineva drag cu un
              card cadou pentru serviciile mele. Scrie-mi pe WhatsApp și
              îl pregătesc.
            </p>
          </div>

          <a href="#programari" class="btn btn-on-blush mt-2"
            >Programează-te acum</a
          >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Decorative gold motif — brand gold token, not a hard-coded hex. */
  .loyalty-gold-motif {
    background: radial-gradient(
      circle,
      var(--color-gold) 0%,
      transparent 65%
    );
  }
</style>
