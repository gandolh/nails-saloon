---
import { site } from "../content/site";
import { img } from "../content/images";
---

<section
  id="acasa"
  class="relative pt-28 md:pt-32 pb-16 md:pb-24 overflow-hidden"
>
  <div
    class="container-page grid md:grid-cols-2 gap-12 md:gap-16 items-center"
  >
    <div class="reveal order-2 md:order-1">
      <span class="label-md uppercase text-[var(--color-secondary)]">
        Manichiură personalizată · lângă Târgu-Jiu
      </span>
      <h1 class="heading-xl mt-4 text-[var(--color-on-surface)]">
        {site.tagline}
      </h1>
      <p
        class="mt-6 text-lg text-[var(--color-on-surface-variant)] max-w-md leading-relaxed"
      >
        {site.description}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href="#programari" class="btn btn-primary">Programează-te acum</a>
        <a
          href="#servicii"
          class="inline-flex items-center min-h-[44px] text-sm font-semibold underline underline-offset-4 text-[var(--color-on-surface)] hover:text-[var(--color-blush-deep)]"
        >
          Vezi serviciile →
        </a>
      </div>
    </div>

    <div class="reveal order-1 md:order-2 relative">
      <div
        class="aspect-[4/5] w-full rounded-[1rem] overflow-hidden bg-[var(--color-surface-container)]"
      >
        <img
          src={img("hero")}
          alt="Detaliu cu unghii manichiurate de Ana"
          class="w-full h-full object-cover"
          width="800"
          height="1000"
        />
      </div>
      <!-- Decorative gold accent -->
      <div
        class="hidden md:block absolute -bottom-4 -left-4 w-20 h-20 rounded-full"
        style="background: radial-gradient(circle at 30% 30%, #C9A961 0%, #C9A961 60%, transparent 70%); opacity: 0.35;"
      >
      </div>
    </div>
  </div>
</section>
