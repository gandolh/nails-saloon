---
import { site, waLink } from "../content/site";
import { img } from "../content/images";
---

<section
  id="acasa"
  class="relative pt-28 md:pt-32 pb-16 md:pb-24 overflow-hidden"
>
  <div
    class="container-page grid md:grid-cols-2 gap-12 md:gap-16 items-center"
  >
    <div class="reveal order-2 md:order-1">
      <h1 class="heading-xl text-[var(--color-on-surface)]">
        {site.tagline}
      </h1>
      <p
        class="mt-6 text-lg text-[var(--color-on-surface-variant)] max-w-md leading-relaxed"
      >
        {site.description}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href={waLink()}
          target="_blank"
          rel="noopener"
          class="btn btn-whatsapp"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            aria-hidden="true"
          >
            <path d="M3 21l1.65-3.8A8.5 8.5 0 1 1 7.8 19.35L3 21z" />
            <path d="M8.5 8.5c0 4 3 7 7 7l1.5-2-2.5-1-1 1c-1 0-3-2-3-3l1-1-1-2.5z" />
          </svg>
          Programează-te pe WhatsApp
        </a>
        <a
          href="#servicii"
          class="inline-flex items-center min-h-[44px] text-sm font-semibold underline underline-offset-4 text-[var(--color-on-surface)] hover:text-[var(--color-blush-deep)]"
        >
          Vezi serviciile →
        </a>
      </div>
    </div>

    <div class="reveal order-1 md:order-2 relative">
      <div
        class="aspect-[4/5] w-full rounded-[1rem] overflow-hidden bg-[var(--color-surface-container)]"
      >
        <img
          src={img("hero")}
          alt="Detaliu cu unghii manichiurate de Ana"
          class="w-full h-full object-cover"
          width="800"
          height="1000"
        />
      </div>
      <!-- Decorative gold accent -->
      <div
        aria-hidden="true"
        class="hero-gold-accent hidden md:block absolute -bottom-4 -left-4 w-20 h-20 rounded-full"
      >
      </div>
    </div>
  </div>
</section>

<style>
  /* Decorative gold glow behind the hero portrait — uses the brand gold token
     rather than a hard-coded hex so it tracks any palette change. */
  .hero-gold-accent {
    background: radial-gradient(
      circle at 30% 30%,
      var(--color-gold) 0%,
      var(--color-gold) 60%,
      transparent 70%
    );
    opacity: 0.35;
  }
</style>
