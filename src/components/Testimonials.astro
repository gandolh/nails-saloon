---
import { testimonials } from "../content/testimonials";
---

<section id="testimoniale" class="section">
  <div class="container-page">
    <div class="reveal max-w-2xl mx-auto text-center">
      <span class="label-md uppercase text-[var(--color-secondary)]">
        Cliente fericite
      </span>
      <h2 class="heading-lg mt-3">Ce spun clientele mele</h2>
      <span class="gold-divider"></span>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="card reveal flex flex-col">
            <div
              class="flex items-center gap-0.5 text-[var(--color-gold)]"
              aria-label={`${t.rating} din 5 stele`}
            >
              {Array.from({ length: t.rating }).map(() => (
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 2l2.9 6.9L22 10l-5.5 4.9L18 22l-6-3.5L6 22l1.5-7.1L2 10l7.1-1.1z" />
                </svg>
              ))}
            </div>
            <blockquote
              class="mt-5 font-display italic text-lg leading-relaxed text-[var(--color-on-surface)]"
              style="font-family: 'Playfair Display', Georgia, serif;"
            >
              “{t.quote}”
            </blockquote>
            <figcaption
              class="mt-6 pt-6 border-t border-[var(--color-outline-variant)] flex items-center justify-between"
            >
              <span class="font-semibold text-[var(--color-on-surface)]">
                {t.author}
              </span>
              <span
                class="label-md uppercase text-[var(--color-on-surface-variant)]"
              >
                Google
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
