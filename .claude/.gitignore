# Claude Code — keep shared project config, ignore machine-local & transient state.

# Machine-local settings & secrets
settings.local.json
.credentials.json
*.local.json

# Transient / per-session state
worktrees/
shell-snapshots/
todos/
projects/
statsig/
history.jsonl
*.log

# Vendored skills/plugins (large, not part of this project's source)
skills/

# But always keep shared, version-controlled project config:
!settings.json
!commands/
!agents/
!hooks/
!.gitignore
