{
  "name": "ana-saloon-bots",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Compliant automation service for Ana Saloon (campaigns / responses / scheduling). Plan: marketing/bots/SCAFFOLD_PLAN.md",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --experimental-strip-types --watch src/server.ts",
    "start": "node --env-file=.env --experimental-strip-types src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bash -c 'shopt -s globstar; node --experimental-strip-types --test src/**/*.test.ts'",
    "lint": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
