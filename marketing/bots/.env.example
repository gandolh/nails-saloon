# ana-saloon-bots — environment template.
# Copy to .env and fill in for live mode. The scaffold runs in MOCK MODE and
# needs none of the secrets. .env is gitignored; .env.example is committed.
# Every name here must match src/core/config.ts.

# --- Mode & server ---
BOTS_MOCK_MODE=true          # true => no real API calls (scaffold default)
LOG_LEVEL=info               # debug | info | warn | error
PORT=8787
BASE_PATH=/bots              # subpath behind nginx/Caddy

# --- Per-bot kill-switches (default off) ---
BOT_WHATSAPP_ENABLED=false
BOT_RESPONSES_ENABLED=false
BOT_SCHEDULER_ENABLED=false
BOT_CAMPAIGNS_ENABLED=false

# --- Ad spend safety ---
ADS_SPEND_ENABLED=false       # master spend kill-switch
ADS_DAILY_CAP_MINOR=5000      # 50.00 RON, in bani (integer)
ADS_LIFETIME_CAP_MINOR=150000 # 1500.00 RON, in bani

# --- Retention (GDPR; see corpus/LEGAL.md) ---
RETENTION_APPOINTMENT_DAYS=365  # 12 months after last appointment
RETENTION_ENQUIRY_DAYS=30       # non-converting enquiries

# --- State ---
DB_PATH=./data/bots.sqlite

# --- Salon / publishing ---
SALON_WHATSAPP_E164=40700000000   # salon WhatsApp (E.164 without '+'), booking path
PUBLISH_SPACING_MS=90000          # min gap between post publishes (live); 0 in mock

# --- Secrets (required only when BOTS_MOCK_MODE=false) ---
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
IG_PAGE_TOKEN=
FB_PAGE_ID=
ADS_ACCESS_TOKEN=
ADS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
NOTIFY_TO=          # where campaign-approval / health alerts go
