---
import { testimonials } from "../content/testimonials";

// Renders nothing when there are no REAL testimonials (the default). We never
// ship invented quotes. To enable: add real reviews to content/testimonials.ts.
---

{
  testimonials.length > 0 && (
    <section id="recenzii" class="section bg-[var(--color-surface)]">
      <div class="container-page">
        <div class="reveal max-w-2xl">
          <span class="m-stripe" aria-hidden="true" />
          <h2 class="heading-lg mt-4">Ce spun clienții</h2>
        </div>
        <ul class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {testimonials.map((t) => (
            <li class="reveal card">
              {/* Rating stars in M Racing Red — the sanctioned enthusiast accent
                  (see DESIGN.md › The M-Color Rule). Filled stars carry the red;
                  empty stars drop to a muted outline so the score reads at a
                  glance and the red marks only what was actually earned. */}
              <div class="flex gap-0.5" aria-label={`${t.rating} din 5`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill={i < t.rating ? "var(--color-m-red)" : "none"}
                    stroke={i < t.rating ? "var(--color-m-red)" : "var(--color-outline)"}
                    stroke-width="1.5"
                    aria-hidden="true"
                  >
                    <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-3 text-[var(--color-on-surface)] leading-relaxed">{t.quote}</blockquote>
              <figcaption class="mt-4 text-sm">
                <span class="font-semibold text-[var(--color-on-surface)]">{t.author}</span>
                <span class="text-[var(--color-on-surface-variant)]"> · {t.car}</span>
              </figcaption>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
