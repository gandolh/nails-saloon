---
import { site, telLink, waLink } from "../content/site";
import MapConsent from "./MapConsent.tsx";

// Phone-first contact. The quote form was removed: for a small workshop the
// call (and WhatsApp, where the owner can ask for a photo of the warning light)
// is the honest, immediate path. No form means no silently-lost lead and no
// inbox to babysit.
//
// `bare` drops the in-section heading when the page's PageHeader carries it.
// `heading` picks the tag: "h1" when this section is the page's primary heading
// (the Contact page), "h2" when it's one section among others.
interface Props {
  bare?: boolean;
  heading?: "h1" | "h2";
}
const { bare = false, heading = "h2" } = Astro.props;
const Heading = heading;
---

<section id="contact" class="section bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)]">
  <div class="container-page">
    {
      !bare && (
        <div class="reveal max-w-2xl">
          <span class="m-stripe" aria-hidden="true" />
          <Heading class="heading-lg mt-4 text-[var(--color-inverse-on-surface)]">Hai cu mașina la noi</Heading>
          <p class="mt-4 text-lg text-[var(--color-inverse-on-surface-variant)]">
            Cel mai rapid e un telefon. Dacă preferi să scrii, trimite-ne un mesaj
            pe WhatsApp, poți atașa și o poză cu martorul aprins sau cu piesa.
          </p>
        </div>
      )
    }

    <div
      class:list={[
        "grid lg:grid-cols-[1fr_1fr] gap-8 lg:gap-12",
        bare ? "mt-0" : "mt-10",
      ]}
    >
      <!-- Left: the two contact actions + details + hours -->
      <div class="reveal space-y-8">
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={telLink()} class="btn btn-primary btn-lg flex-1" data-cta="contact-call">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span>{site.phone}</span>
          </a>
          <a href={waLink()} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg flex-1" data-cta="contact-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.004c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.8 14.13c-.24.68-1.42 1.32-1.95 1.36-.5.05-1.13.26-3.8-.8-3.2-1.26-5.26-4.5-5.42-4.71-.16-.21-1.3-1.73-1.3-3.3 0-1.57.82-2.34 1.11-2.66.29-.32.64-.4.85-.4.21 0 .43 0 .61.01.2.01.46-.07.72.55.27.64.92 2.2 1 2.36.08.16.13.35.03.56-.1.21-.16.34-.31.53-.16.18-.33.41-.47.55-.16.16-.32.33-.14.64.18.32.8 1.32 1.72 2.14 1.18 1.05 2.18 1.38 2.49 1.54.31.16.49.13.67-.08.18-.21.77-.9.98-1.21.21-.32.42-.26.71-.16.29.11 1.84.87 2.16 1.03.31.16.52.24.6.37.08.13.08.74-.16 1.42z"/>
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>

        <dl class="grid sm:grid-cols-2 gap-6 border-t border-white/10 pt-6">
          <div>
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Adresă</dt>
            <dd class="mt-1.5 text-[var(--color-inverse-on-surface)]">
              {site.address}<br />{site.city}, jud. {site.county}
            </dd>
          </div>
          <div>
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Email</dt>
            <dd class="mt-1.5">
              <a href={`mailto:${site.email}`} class="text-[var(--color-primary-bright)] hover:underline">{site.email}</a>
            </dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Program</dt>
            <dd>
              <ul class="mt-2 divide-y divide-white/10">
                {
                  site.hours.map((h) =>
                    h ? (
                      <li class="flex justify-between gap-4 py-1.5">
                        <span class="text-[var(--color-inverse-on-surface-variant)]">{h.day}</span>
                        <span class="font-semibold text-[var(--color-inverse-on-surface)]">{h.value}</span>
                      </li>
                    ) : null,
                  )
                }
              </ul>
            </dd>
          </div>
        </dl>
      </div>

      <!-- Right: the map -->
      <div class="reveal">
        <div class="overflow-hidden rounded-xl border border-white/10 aspect-[4/3] lg:h-full">
          <MapConsent client:visible lat={site.geo.lat} lng={site.geo.lng} label={site.name} />
        </div>
      </div>
    </div>
  </div>
</section>
