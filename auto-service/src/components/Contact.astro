---
import { site, telLink, waLink } from "../content/site";
import { withBase } from "../content/url";
import MapConsent from "./MapConsent.tsx";

// Placeholder Formspree endpoint — owner replaces with the real form ID and
// signs a DPA (see corpus/LEGAL.md). The form is the SECONDARY path; phone and
// WhatsApp come first for an auto service.
const FORMSPREE_ENDPOINT = "https://formspree.io/f/your-form-id";
---

<section id="contact" class="section bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)]">
  <div class="container-page">
    <div class="reveal max-w-2xl">
      <span class="m-stripe" aria-hidden="true"></span>
      <h2 class="heading-lg mt-4 text-[var(--color-inverse-on-surface)]">Hai cu mașina la noi</h2>
      <p class="mt-4 text-lg text-[var(--color-inverse-on-surface-variant)]">
        Cel mai rapid e un telefon. Dacă preferi, scrie-ne pe WhatsApp sau
        completează formularul și revenim noi.
      </p>
    </div>

    <div class="mt-10 grid lg:grid-cols-[1fr_1fr] gap-8 lg:gap-12">
      <!-- Left: contact details + hours + map -->
      <div class="reveal space-y-8">
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={telLink()} class="btn btn-primary btn-lg flex-1" data-cta="contact-call">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span>{site.phone}</span>
          </a>
          <a href={waLink()} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg flex-1" data-cta="contact-whatsapp">
            WhatsApp
          </a>
        </div>

        <dl class="grid sm:grid-cols-2 gap-6 border-t border-white/10 pt-6">
          <div>
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Adresă</dt>
            <dd class="mt-1.5 text-[var(--color-inverse-on-surface)]">
              {site.address}<br />{site.city}, jud. {site.county}
            </dd>
          </div>
          <div>
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Email</dt>
            <dd class="mt-1.5">
              <a href={`mailto:${site.email}`} class="text-[var(--color-primary-bright)] hover:underline">{site.email}</a>
            </dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="eyebrow text-[var(--color-inverse-on-surface-variant)]">Program</dt>
            <dd>
              <ul class="mt-2 divide-y divide-white/10">
                {
                  site.hours.map((h) =>
                    h ? (
                      <li class="flex justify-between gap-4 py-1.5">
                        <span class="text-[var(--color-inverse-on-surface-variant)]">{h.day}</span>
                        <span class="font-semibold text-[var(--color-inverse-on-surface)]">{h.value}</span>
                      </li>
                    ) : null,
                  )
                }
              </ul>
            </dd>
          </div>
        </dl>

        <div class="overflow-hidden rounded-xl border border-white/10 aspect-[16/10]">
          <MapConsent client:visible lat={site.geo.lat} lng={site.geo.lng} label={site.name} />
        </div>
      </div>

      <!-- Right: quote form -->
      <div class="reveal">
        <form
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="rounded-xl bg-[var(--color-surface-container-lowest)] p-6 md:p-8 text-[var(--color-on-surface)]"
        >
          <h3 class="heading-md !text-[1.25rem]">Cere o ofertă</h3>
          <p class="mt-1 text-sm text-[var(--color-on-surface-variant)]">
            Spune-ne câteva detalii și revenim cu un răspuns.
          </p>

          <div class="mt-5 grid gap-4">
            <div class="grid sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-sm font-semibold">Nume</span>
                <input class="input mt-1.5" type="text" name="nume" autocomplete="name" required />
              </label>
              <label class="block">
                <span class="text-sm font-semibold">Telefon</span>
                <input class="input mt-1.5" type="tel" name="telefon" autocomplete="tel" required />
              </label>
            </div>
            <label class="block">
              <span class="text-sm font-semibold">Model și an BMW</span>
              <input class="input mt-1.5" type="text" name="masina" placeholder="ex. Seria 3 (F30), 2015, 320d" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold">Cu ce te putem ajuta?</span>
              <textarea class="input mt-1.5" name="mesaj" rows="4" placeholder="Descrie pe scurt problema sau lucrarea dorită." required></textarea>
            </label>

            <!-- GDPR: NO mandatory consent checkbox. Legal basis is art. 6(1)(b)
                 precontractual measures; we inform instead of asking consent. -->
            <p class="text-xs leading-relaxed text-[var(--color-on-surface-variant)]">
              Prin trimiterea formularului ne dai datele necesare ca să te
              contactăm și să-ți pregătim o ofertă (temei: art. 6(1)(b) GDPR).
              Vezi
              <a href={withBase("/confidentialitate/")} class="font-semibold text-[var(--color-primary)] underline underline-offset-2">Politica de confidențialitate</a>.
            </p>

            <!-- Optional, UNCHECKED marketing consent (art. 6(1)(a)). -->
            <label class="flex items-start gap-2.5 text-xs text-[var(--color-on-surface-variant)]">
              <input type="checkbox" name="marketing" value="da" class="mt-0.5 h-4 w-4 accent-[var(--color-primary)]" />
              <span>Vreau să primesc, opțional, oferte și noutăți de la {site.name}.</span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg w-full mt-1" data-cta="contact-form">
              Trimite cererea
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
