# Caddyfile template for the shared side-projects VPS.
#
# The real `Caddyfile` is git-ignored (server-specific). Copy this to
# `deploy/Caddyfile` and adjust, then let `npm run deploy:pre` upload + validate
# it, or install manually at /etc/caddy/Caddyfile and:
#   sudo caddy validate --config /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# This VPS already hosts the `saloon` site under /saloon. ADD the BavAuto block
# to the SAME `:80 { ... }` server block on the server — don't ship a second
# server block that would conflict. The block below is the piece to add.
#
# handle_path STRIPS the matched prefix before serving, so files live at the
# root of the project's dir (e.g. /var/www/auto-service/index.html), matching
# the PUBLIC_BASE=/auto-service build.

:80 {
	# --- Ana Saloon -> http://<ip>/saloon (existing) ----------------------
	handle_path /saloon/* {
		root * /var/www/saloon
		try_files {path} {path}/ {path}.html
		file_server
	}

	# --- BavAuto Gorj -> http://<ip>/auto-service -------------------------
	handle_path /auto-service/* {
		root * /var/www/auto-service
		# Static multi-page site: serve the file, then dir index, then the
		# pretty-URL .html, else 404. Matches Astro's default output.
		try_files {path} {path}/ {path}.html
		file_server
	}

	# Anything not matched above (e.g. bare "/") → simple landing/404.
	handle {
		respond "Nothing here. Try /saloon or /auto-service" 404
	}
}
