---
// Self-hosted fonts (no Google Fonts CDN — GDPR: avoids transmitting visitor
// IPs to Google). latin + latin-ext subsets cover Romanian diacritics.
import "@fontsource/manrope/latin-400.css";
import "@fontsource/manrope/latin-ext-400.css";
import "@fontsource/manrope/latin-500.css";
import "@fontsource/manrope/latin-ext-500.css";
import "@fontsource/manrope/latin-600.css";
import "@fontsource/manrope/latin-ext-600.css";
import "@fontsource/manrope/latin-700.css";
import "@fontsource/manrope/latin-ext-700.css";
// Fraunces — variable display face (opsz axis + weight 100–900) covering the
// roman and italic styles we use. One variable file per style, and latin-ext
// carries the Romanian diacritics.
import "@fontsource-variable/fraunces/opsz.css";
import "@fontsource-variable/fraunces/opsz-italic.css";
import "../styles/global.css";
import { site } from "../content/site";
import { img } from "../content/images";
import { withBase } from "../content/url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} · Manichiură personalizată lângă Târgu-Jiu`,
  description = site.description,
} = Astro.props;

const canonical = "https://anasaloon.ro/";

// Root-relative for meta tags; absolute (canonical + path) for JSON-LD.
const ogImage = img("og-image");
const ogImageAbsolute = `${canonical}${ogImage.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fff8f6" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts are self-hosted via @fontsource (imported in the frontmatter) -->

    <!-- JSON-LD: LocalBusiness / BeautySalon -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BeautySalon",
        name: site.name,
        description: site.description,
        image: ogImageAbsolute,
        url: canonical,
        telephone: `+${site.phoneE164}`,
        address: {
          "@type": "PostalAddress",
          streetAddress: site.address,
          addressLocality: site.city,
          addressRegion: site.county,
          postalCode: site.postalCode,
          addressCountry: "RO",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: site.geo.lat,
          longitude: site.geo.lng,
        },
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            opens: "09:00",
            closes: "19:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Saturday",
            opens: "10:00",
            closes: "16:00",
          },
        ],
        sameAs: [
          site.social.instagram,
          site.social.facebook,
          site.social.tiktok,
        ],
      })}
    />
  </head>
  <body>
    <a
      href="#acasa"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded-full"
    >
      Sari la conținut
    </a>
    <slot />

    <script is:inline>
      // Scroll-triggered fade-in. Only hide-then-reveal when JS + observer are
      // available; otherwise the CSS default leaves all .reveal content visible
      // (no-JS, crawlers, link-preview bots). Honour reduced-motion too.
      //
      // CRITICAL failsafe: a JS-capable client that never scrolls — a headless
      // renderer, a link-preview / social-card bot, or a backgrounded tab where
      // IntersectionObserver is throttled — would otherwise leave every
      // not-yet-seen .reveal stuck at opacity:0 and capture a blank page. So we
      // (a) reveal anything already in the first viewport synchronously, and
      // (b) force-reveal everything after a short timeout regardless of scroll.
      // The reveal is then only ever a progressive enhancement on top of an
      // already-visible default; it can never hide content.
      (function () {
        const prefersReduced =
          typeof matchMedia === "function" &&
          matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (typeof IntersectionObserver === "undefined" || prefersReduced) {
          return; // leave content visible, skip animation entirely
        }

        // Gate the hidden initial state on JS being present.
        document.documentElement.classList.add("js-reveal");
        const reveals = Array.prototype.slice.call(
          document.querySelectorAll(".reveal"),
        );

        function show(el) {
          el.classList.add("is-visible");
        }

        const io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                show(entry.target);
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "-40px 0px" },
        );
        reveals.forEach(function (el) {
          io.observe(el);
        });

        // (a) Reveal whatever is already on screen at load, without waiting for
        // a scroll or even the observer's first async callback.
        const vh = window.innerHeight || document.documentElement.clientHeight;
        reveals.forEach(function (el) {
          if (el.getBoundingClientRect().top < vh) {
            show(el);
            io.unobserve(el);
          }
        });

        // (b) Hard failsafe: after a short grace period, reveal everything that
        // is still hidden, whether or not the client ever scrolled. Real users
        // will have triggered the on-scroll reveals long before this fires; it
        // exists purely so the page can never be captured blank. These snap in
        // with no transition (.reveal-now) since they're a correction, not an
        // entrance.
        function revealAll() {
          reveals.forEach(function (el) {
            if (!el.classList.contains("is-visible")) {
              el.classList.add("reveal-now");
              show(el);
            }
          });
          io.disconnect();
        }
        // 2.5s comfortably exceeds a normal "time to first scroll" (so engaged
        // users still get the on-scroll animation) while staying short enough
        // that headless/preview captures don't grab a blank page.
        window.setTimeout(revealAll, 2500);
      })();
    </script>
  </body>
</html>
