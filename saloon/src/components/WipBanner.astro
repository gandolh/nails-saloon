---
// Sticky top banner: a soft-launch invitation (not an "under construction"
// apology — that levied a trust tax at first paint). Frames WhatsApp as the
// booking channel. Sits above the fixed Nav and sets the --wip-banner-h CSS
// var so the Nav can offset itself and they never overlap. Purely
// presentational, Romanian-only (no EN — see project memory).
---

<div id="wip-banner">
  <div class="container-page wip-banner__inner">
    <span class="wip-banner__dot" aria-hidden="true"></span>
    <span class="wip-banner__text">
      Site în lucru. Pentru programări, scrie-mi oricând pe WhatsApp.
    </span>
  </div>
</div>

<style>
  /* Mobile: a normal in-flow banner at the very top that scrolls away with
     the page. Desktop (>=768px): sticky/fixed above the Nav. */
  #wip-banner {
    position: static;
    inset-inline: 0;
    background-color: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    border-bottom: 1px solid var(--color-gold);
  }

  @media (min-width: 768px) {
    #wip-banner {
      position: fixed;
      top: 0;
      z-index: 50; /* above the Nav (z-40) */
    }
  }

  .wip-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding-block: 0.5rem;
    text-align: center;
  }

  .wip-banner__text {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .wip-banner__dot {
    flex: none;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--color-gold);
  }
</style>

<script is:inline>
  // Publish the banner's real height as a CSS var so the fixed Nav (and the
  // skip-link / scroll offsets) can sit just below it. Only on desktop
  // (>=768px) where the banner is fixed; on mobile it's in-flow and scrolls
  // away, so the Nav sits at top:0 (the var stays at its 0px fallback).
  (function () {
    const banner = document.getElementById("wip-banner");
    if (!banner) return;
    const mq = window.matchMedia("(min-width: 768px)");
    function setHeight() {
      document.documentElement.style.setProperty(
        "--wip-banner-h",
        mq.matches ? banner.offsetHeight + "px" : "0px",
      );
    }
    setHeight();
    window.addEventListener("resize", setHeight, { passive: true });
    mq.addEventListener("change", setHeight);
  })();
</script>
