---
import { site } from "../content/site";
import { withBase } from "../content/url";

const year = new Date().getFullYear();
const links = [
  { href: "/#acasa", label: "Acasă" },
  { href: "/#servicii", label: "Servicii" },
  { href: "/#galerie", label: "Galerie" },
  { href: "/#contact", label: "Contact" },
];
const legalLinks = [
  { href: "/confidentialitate/", label: "Politică de confidențialitate" },
  { href: "/termeni/", label: "Termeni și condiții" },
  { href: "/cookie-uri/", label: "Politică de cookie-uri" },
];
---

<footer
  class="bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)] mt-12"
>
  <div class="container-page py-16 grid gap-12 md:grid-cols-4">
    <div>
      <span class="wordmark text-3xl">Unghii by Ana</span>
      <p class="mt-4 text-sm opacity-80 max-w-xs">
        {site.description}
      </p>
    </div>

    <nav class="flex flex-col gap-1">
      <span class="label-md opacity-60 uppercase mb-2">Navigare</span>
      {
        links.map((link) => (
          <a
            href={withBase(link.href)}
            class="inline-flex items-center min-h-[44px] text-sm opacity-90 hover:opacity-100 hover:underline underline-offset-4"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <nav class="flex flex-col gap-1">
      <span class="label-md opacity-60 uppercase mb-2">Legal</span>
      {
        legalLinks.map((link) => (
          <a
            href={withBase(link.href)}
            class="inline-flex items-center min-h-[44px] text-sm opacity-90 hover:opacity-100 hover:underline underline-offset-4"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex flex-col gap-1">
      <span class="label-md opacity-60 uppercase mb-2">Contact</span>
      <a
        href={`tel:+${site.phoneE164}`}
        class="inline-flex items-center min-h-[44px] text-sm opacity-90 hover:opacity-100"
        >{site.phone}</a
      >
      <a
        href={`mailto:${site.email}`}
        class="inline-flex items-center min-h-[44px] text-sm opacity-90 hover:opacity-100"
        >{site.email}</a
      >
      <p class="text-sm opacity-90 mt-1">
        {site.address}, {site.city}
      </p>

      <div class="flex items-center gap-2 mt-3">
        <a
          href={site.social.instagram}
          aria-label="Instagram"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-11 h-11 -m-2 opacity-80 hover:opacity-100"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a
          href={site.social.facebook}
          aria-label="Facebook"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-11 h-11 -m-2 opacity-80 hover:opacity-100"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a
          href={`https://wa.me/${site.whatsappE164}`}
          aria-label="WhatsApp"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-11 h-11 -m-2 opacity-80 hover:opacity-100"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 21l1.65-3.8A8.5 8.5 0 1 1 7.8 19.35L3 21z"/>
            <path d="M8.5 8.5c0 4 3 7 7 7l1.5-2-2.5-1-1 1c-1 0-3-2-3-3l1-1-1-2.5z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <style>
    /* The mobile WhatsApp FAB is fixed over the bottom of the page; pad the
       final legal block on small screens so its fixed bar never covers the
       CUI / ANPC line. Desktop has no FAB, so no padding needed. */
    @media (max-width: 767px) {
      .footer-legal {
        padding-bottom: calc(5rem + env(safe-area-inset-bottom));
      }
    }
  </style>

  <!-- Business identification (Legea 365/2002 art. 5) + ANPC SAL -->
  <div class="footer-legal border-t border-white/10 py-6 text-xs opacity-70">
    <div class="container-page space-y-3">
      <p class="leading-relaxed">
        {site.legal.legalName} · CUI: {site.legal.cui} · Reg. Com.: {
          site.legal.regNumber
        }{
          site.legal.form === "SRL" && site.legal.shareCapital
            ? ` · Capital social: ${site.legal.shareCapital}`
            : ""
        } · {site.address}, {site.city}, jud. {site.county}
      </p>
      <div
        class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
      >
        <p>© {year} {site.name}. Toate drepturile rezervate.</p>
        <a
          href="https://reclamatiisal.anpc.ro/"
          target="_blank"
          rel="noopener"
          aria-label="ANPC: Soluționarea Alternativă a Litigiilor"
          class="inline-flex items-center gap-2 hover:opacity-100"
        >
          <span
            class="inline-flex items-center justify-center rounded bg-white/10 px-2 py-1 label-md uppercase"
            >ANPC</span
          >
          <span>Soluționarea Alternativă a Litigiilor (SAL)</span>
        </a>
      </div>
    </div>
  </div>
</footer>
