---
import Base from "./Base.astro";
import Footer from "../components/Footer.astro";
import { site } from "../content/site";
import { withBase } from "../content/url";

interface Props {
  title: string;
  description?: string;
  updated?: string;
}

const {
  title,
  description = `${title} · ${site.name}`,
  updated = site.legal.documentsUpdated,
} = Astro.props;
---

<Base title={`${title} · ${site.name}`} description={description}>
  <header class="border-b border-[var(--color-outline-variant)] bg-[var(--color-surface-container-lowest)]">
    <div class="container-page flex items-center justify-between py-5">
      <a href={withBase("/")} class="wordmark text-2xl md:text-[1.75rem]">{site.name}</a>
      <a
        href={withBase("/")}
        class="text-sm font-semibold text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)] transition-colors"
      >
        ← Înapoi la site
      </a>
    </div>
  </header>

  <main class="container-page max-w-3xl py-12 md:py-20">
    <h1 class="heading-lg">{title}</h1>
    <span class="guyline mt-4"></span>
    <p class="mt-3 text-sm text-[var(--color-on-surface-variant)]">
      Ultima actualizare: {updated}
    </p>

    <article class="legal-prose mt-10">
      <slot />
    </article>
  </main>

  <Footer />
</Base>

<style is:global>
  .legal-prose {
    color: var(--color-on-surface-variant);
    line-height: 1.7;
    font-size: 1rem;
  }
  .legal-prose h2 {
    font-family: var(--font-display);
    font-weight: 750;
    font-size: clamp(1.3rem, 3vw, 1.6rem);
    letter-spacing: -0.018em;
    color: var(--color-on-surface);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .legal-prose h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-on-surface);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .legal-prose p {
    margin-bottom: 1rem;
  }
  .legal-prose ul,
  .legal-prose ol {
    margin: 0.5rem 0 1.25rem;
    padding-left: 1.5rem;
    list-style: disc;
  }
  .legal-prose ol {
    list-style: decimal;
  }
  .legal-prose li {
    margin-bottom: 0.5rem;
  }
  .legal-prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
  .legal-prose a:hover {
    color: var(--color-primary-hover);
  }
  .legal-prose strong {
    color: var(--color-on-surface);
    font-weight: 700;
  }
  .legal-prose hr {
    border: none;
    border-top: 1px solid var(--color-outline-variant);
    margin: 2rem 0;
  }
  .legal-prose .note {
    background-color: var(--color-surface-container);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
</style>
