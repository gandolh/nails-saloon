---
// Compact dark page header for subpages (which have no hero). Carries the page
// <h1> and sits directly under the solid nav, echoing the hero's deep-canopy
// surface and guy-line so the brand reads continuous across routes.
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="hero-grain relative overflow-hidden bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)]">
  <!-- a soft clay lamp-glow in the corner, echoing the hero's blue-hour warmth -->
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full"
    style="background:radial-gradient(closest-side, oklch(58% 0.12 55 / 0.22), transparent)"
    aria-hidden="true"
  >
  </div>
  <div class="container-page relative pt-12 pb-12 md:pt-16 md:pb-16">
    <div class="reveal flex items-center gap-3">
      <span class="guyline guyline--bright" aria-hidden="true"></span>
      <span class="eyebrow text-[var(--color-inverse-on-surface-variant)]">{eyebrow}</span>
    </div>
    <h1 class="reveal heading-xl mt-4 !text-[clamp(2rem,5vw,3.25rem)] text-[var(--color-inverse-on-surface)]">
      {title}
    </h1>
    {
      lead && (
        <p class="reveal mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-inverse-on-surface-variant)]">
          {lead}
        </p>
      )
    }
  </div>
  <span class="guyline guyline--bright guyline--full absolute inset-x-0 bottom-0 opacity-60" aria-hidden="true"></span>
</section>
