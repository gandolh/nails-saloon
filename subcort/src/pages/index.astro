---
import Base from "../layouts/Base.astro";
import DemoBanner from "../components/DemoBanner.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { site } from "../content/site";
import { img } from "../content/images";
import { withBase } from "../content/url";
import { steps } from "../content/zone";
import { gallery } from "../content/gallery";
import { amenities } from "../content/tents";

const heroImg = img("hero");
// Show the three "incluse" amenities as the comfort teaser on the home page.
const included = amenities.filter((a) => a.kind === "inclus");
---

<Base path="/">
  <DemoBanner />
  <Nav current="/" />

  <main id="main">
    <!-- ============================ HERO ============================
         Editorial blue-hour composition: an oversized slab headline carries
         the page, with the lit-tent illustration anchored as a deliberate
         right-hand panel (not a washed-out backdrop). The guy-line runs the
         full width as real structure between headline and the inline facts. -->
    <section class="hero-grain relative overflow-hidden bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)]">
      <!-- Illustration: a framed scene anchored to the right on desktop; a soft
           band behind the text on mobile. Brightened so it reads as an image. -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <img
          src={heroImg}
          alt=""
          class="absolute right-0 top-0 h-full w-full object-cover opacity-[0.5] md:w-[58%] md:opacity-100"
          loading="eager"
          decoding="async"
        />
        <!-- left-to-right wash so the headline keeps full contrast over the art -->
        <div
          class="absolute inset-0"
          style="background:linear-gradient(95deg, oklch(24% 0.05 155) 0%, oklch(24% 0.05 155) 34%, oklch(24% 0.05 155 / 0.78) 50%, oklch(24% 0.05 155 / 0.28) 72%, oklch(24% 0.05 155 / 0.55) 100%)"
        >
        </div>
        <!-- top + bottom vignette to seat the nav and the next section -->
        <div
          class="absolute inset-x-0 top-0 h-32"
          style="background:linear-gradient(180deg, oklch(20% 0.04 155 / 0.8), transparent)"
        >
        </div>
      </div>

      <div class="container-page relative pt-[calc(var(--nav-h,5rem)+3.5rem)] pb-16 md:pt-[calc(var(--nav-h,5rem)+5.5rem)] md:pb-24">
        <div class="max-w-3xl">
          <div class="reveal flex items-center gap-3">
            <span class="section-index__num !text-[var(--color-accent-bright)]">01</span>
            <span class="guyline guyline--bright" aria-hidden="true"></span>
            <span class="eyebrow text-[var(--color-inverse-on-surface-variant)]">
              {site.county} · {site.region}
            </span>
          </div>

          <h1 class="reveal heading-xl mt-6 text-[var(--color-inverse-on-surface)]">
            Un spațiu <span class="ink-mark ink-mark--bright">pregătit</span>,<br
            />oriunde ai nevoie de el.
          </h1>

          <p class="reveal mt-7 max-w-xl text-lg leading-relaxed text-[var(--color-inverse-on-surface-variant)]">
            Aducem cortul la tine, îl montăm exact cum vrei și asigurăm încălzire
            sau răcire, în funcție de sezon. Tu te ocupi de eveniment, noi de
            spațiul în care are loc.
          </p>
        </div>

        <!-- full-width guy-line, then the inline facts riding on it -->
        <span class="guyline guyline--bright guyline--full reveal mt-12 !h-[3px] opacity-70" aria-hidden="true"></span>

        <dl class="reveal mt-7 grid grid-cols-2 gap-x-8 gap-y-7 sm:flex sm:flex-wrap sm:gap-x-16 max-w-2xl">
          <div>
            <dt class="text-sm text-[var(--color-inverse-on-surface-variant)]">Capacitate</dt>
            <dd class="mt-1.5 font-display text-2xl font-bold tnum text-[var(--color-inverse-on-surface)]">40 – 320 invitați</dd>
          </div>
          <div>
            <dt class="text-sm text-[var(--color-inverse-on-surface-variant)]">Montaj complet</dt>
            <dd class="mt-1.5 font-display text-2xl font-bold text-[var(--color-inverse-on-surface)]">La tine acasă</dd>
          </div>
          <div>
            <dt class="text-sm text-[var(--color-inverse-on-surface-variant)]">Confort</dt>
            <dd class="mt-1.5 font-display text-2xl font-bold text-[var(--color-inverse-on-surface)]">Cald sau răcoros</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ===================== CE FACEM (intro) ====================== -->
    <section class="section">
      <div class="container-page grid gap-10 md:grid-cols-[1.1fr_1fr] md:items-center md:gap-16">
        <div class="reveal">
          <div class="section-index">
            <span class="section-index__num">02</span>
            <span class="guyline" aria-hidden="true"></span>
            <span class="eyebrow">Ce facem</span>
          </div>
          <h2 class="heading-lg mt-5">Cortul potrivit, montat <span class="ink-mark">cap-coadă</span></h2>
          <p class="mt-5 max-w-prose text-[var(--color-on-surface-variant)] leading-relaxed">
            Subcort este un serviciu de logistică pentru evenimente: venim cu
            structura, o ridicăm pe terenul tău și o pregătim complet: pardoseală,
            pereți, iluminat și climatizare. Lăsăm un spațiu gata de folosit,
            potrivit oricărei ocazii, și revenim după eveniment ca să demontăm.
          </p>
          <p class="mt-4 max-w-prose text-[var(--color-on-surface-variant)] leading-relaxed">
            Nu vindem o atmosferă anume. Pregătim un spațiu solid și confortabil,
            iar restul rămâne în mâinile tale.
          </p>
        </div>

        <ul class="reveal panel p-7 md:p-9 space-y-5">
          {
            included.map((a) => (
              <li class="flex gap-4">
                <span class="mt-1 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary-container)] text-[var(--color-on-primary-container)]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </span>
                <div>
                  <h3 class="font-display text-lg font-bold text-[var(--color-on-surface)]">{a.title}</h3>
                  <p class="mt-1 text-sm text-[var(--color-on-surface-variant)] leading-relaxed">{a.description}</p>
                </div>
              </li>
            ))
          }
          <li class="pt-2">
            <a href={withBase("/corturi/")} class="inline-flex items-center gap-2 text-sm font-bold text-[var(--color-primary)] hover:text-[var(--color-primary-hover)]">
              Vezi corturile și dotările
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- ===================== CUM FUNCȚIONEAZĂ ====================== -->
    <section class="section bg-[var(--color-surface-container-low)] border-y border-[var(--color-outline-variant)]">
      <div class="container-page">
        <div class="reveal max-w-2xl">
          <div class="section-index">
            <span class="section-index__num">03</span>
            <span class="guyline" aria-hidden="true"></span>
            <span class="eyebrow">Pas cu pas</span>
          </div>
          <h2 class="heading-lg mt-5">Cum funcționează</h2>
          <p class="mt-4 text-[var(--color-on-surface-variant)] leading-relaxed">
            Patru pași, de la prima discuție până la demontare. De logistică ne
            ocupăm noi, cap-coadă.
          </p>
        </div>

        <ol class="timeline reveal mt-14">
          {
            steps.map((s) => (
              <li class="timeline__step">
                <span class="timeline__node tnum" aria-hidden="true">{s.n}</span>
                <h3 class="heading-md">{s.title}</h3>
                <p class="mt-2.5 text-sm text-[var(--color-on-surface-variant)] leading-relaxed">{s.description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ========================= GALERIE ========================== -->
    <section class="section">
      <div class="container-page">
        <div class="reveal flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <div class="section-index">
              <span class="section-index__num">04</span>
              <span class="guyline" aria-hidden="true"></span>
              <span class="eyebrow">Galerie</span>
            </div>
            <h2 class="heading-lg mt-5">Cum arată</h2>
            <p class="mt-4 text-[var(--color-on-surface-variant)] leading-relaxed">
              Imagini orientative ale spațiului pregătit și ale montajului.
              Atmosfera o dai tu; noi pregătim cadrul.
            </p>
          </div>
        </div>

        <!-- Editorial mosaic: a tall feature tile leads, the rest support it. -->
        <div class="reveal mt-12 grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
          {
            gallery.map((g, i) => (
              <figure
                class:list={[
                  "group relative overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-outline-variant)] bg-[var(--color-inverse-surface)]",
                  i === 0
                    ? "sm:col-span-2 sm:row-span-2 aspect-[16/10] sm:aspect-auto"
                    : "aspect-[4/3]",
                ]}
              >
                <img
                  src={img(g.name)}
                  alt={g.alt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-cover transition duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
                />
                <span
                  class="absolute left-0 top-0 h-[3px] w-full origin-left scale-x-0 bg-gradient-to-r from-[var(--color-primary-bright)] to-[var(--color-accent-bright)] transition-transform duration-500 ease-out group-hover:scale-x-100"
                  aria-hidden="true"
                ></span>
                <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[oklch(22%_0.045_155_/_0.92)] via-[oklch(22%_0.045_155_/_0.4)] to-transparent p-4 pt-12 text-sm font-semibold text-[var(--color-inverse-on-surface)]">
                  {g.alt}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
