---
import Base from "../layouts/Base.astro";
import DemoBanner from "../components/DemoBanner.astro";
import Nav from "../components/Nav.astro";
import PageHeader from "../components/PageHeader.astro";
import Footer from "../components/Footer.astro";
import { site } from "../content/site";
import { services } from "../content/services";

// Inline icon set (stroke, currentColor) keyed by service.icon.
const icons: Record<string, string> = {
  catering: `<path d="M3 11h18M5 11V8a7 7 0 0 1 14 0v3M4 11l1 9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1l1-9"/>`,
  music: `<circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/><path d="M9 18V5l12-2v11"/>`,
  decor: `<path d="M12 3v4M12 21v-4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M3 12h4M17 12h4M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/><circle cx="12" cy="12" r="3"/>`,
};
---

<Base
  path="/servicii/"
  title={`Servicii prin parteneri · ${site.name}`}
  description="Pe lângă cort, coordonăm catering, muzică și decor prin parteneri locali, la cerere și contra cost. Tu alegi, noi ne ocupăm de logistică în cort."
>
  <DemoBanner />
  <Nav current="/servicii/" solid />

  <main id="main">
    <PageHeader
      eyebrow="Servicii"
      title="Mai mult decât cortul, prin parteneri"
      lead="Dacă vrei, ne ocupăm și de ce se întâmplă sub cort. Coordonăm catering, muzică și decor prin firme locale, la cerere și contra cost. Cortul rămâne baza neutră peste care se construiește restul."
    />

    <section class="section">
      <div class="container-page">
        <div class="grid gap-6 md:grid-cols-3">
          {
            services.map((s) => (
              <article class="reveal card flex flex-col">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-primary-container)] text-[var(--color-on-primary-container)]">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[s.icon]} />
                </span>
                <h2 class="heading-md mt-5">{s.title}</h2>
                <p class="mt-3 text-sm text-[var(--color-on-surface-variant)] leading-relaxed">{s.description}</p>
              </article>
            ))
          }
        </div>

        <!-- The "prin parteneri" framing, stated once -->
        <div class="reveal mt-10 panel p-7 md:p-9">
          <div class="flex flex-col gap-4 md:flex-row md:items-start">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-on-accent-soft)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <div>
              <h2 class="font-display text-xl font-bold text-[var(--color-on-surface)]">Toate, prin parteneri locali</h2>
              <p class="mt-2 max-w-prose text-[var(--color-on-surface-variant)] leading-relaxed">
                Aceste servicii sunt asigurate de furnizori din zonă, cu care
                lucrăm. Le coordonăm pentru tine ca să fie la locul lor înainte
                de eveniment, dar alegerea îți aparține și costul lor se adaugă
                separat de cort. Nu impunem un pachet fix.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
