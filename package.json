{
  "name": "presentation-sites",
  "private": true,
  "description": "Monorepo of presentation/marketing sites. Each site is a self-contained project in its own top-level directory.",
  "scripts": {
    "saloon": "npm --prefix saloon run",
    "saloon:install": "npm --prefix saloon install",
    "saloon:dev": "npm --prefix saloon run dev",
    "saloon:build": "npm --prefix saloon run build",
    "saloon:preview": "npm --prefix saloon run preview",
    "saloon:deploy": "npm --prefix saloon run deploy:push",
    "saloon:deploy:all": "npm --prefix saloon run deploy:all",
    "saloon:bots": "npm --prefix saloon/marketing/bots run check"
  }
}
