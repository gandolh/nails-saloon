
SSH_HOST=<alias>
BASE_PATH=/saloon

# Absolute dir on the server that Caddy serves for this project.
REMOTE_DIR=<REMOTE_DIR>

# Public URL shown on success (informational only).
PUBLIC_URL=<PUBLIC_URL>

REMOTE_CADDYFILE=<Caddy_dir>

# pre-deploy will print the commands for you to run manually instead if this false
SUDO_NOPASSWD=false
